rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public coaching intake form (create only; no public reads)
    match /coaching_requests/{requestId} {
      allow read, update, delete: if false;
      allow create: if request.resource.data.fullName is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.fullName.size() < 500
        && request.resource.data.email is string
        && request.resource.data.email.size() < 320
        && request.resource.data.cityOrZip is string
        && request.resource.data.cityOrZip.size() > 0
        && request.resource.data.cityOrZip.size() < 200
        && request.resource.data.helpTopics is list
        && request.resource.data.availability is list
        && request.resource.data.preferredContact is string
        && request.resource.data.supportDescription is string
        && request.resource.data.supportDescription.size() > 0
        && request.resource.data.supportDescription.size() < 8000;
    }

    // Founder contact form (create only; no public reads)
    match /founder_contact_requests/{requestId} {
      allow read, update, delete: if false;
      allow create: if request.resource.data.keys().hasOnly([
          'firstName',
          'lastName',
          'phone',
          'email',
          'message',
          'createdAt',
          'status',
        ])
        && request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.firstName.size() < 200
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() > 0
        && request.resource.data.lastName.size() < 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() < 40
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 320
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 8000
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
    }
  }
}
