# Copy to .env.local and fill in from Firebase console → Project settings → Your apps.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: publish jobs from a Google Sheet (enable Sheets API + API key in Google Cloud)
# Spreadsheet must include header row: id, title, organization, category, location, type, supportLevel, description, tags, postedAt
# Tab name defaults to "Jobs" — override range if your sheet tab/columns differ.
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=
VITE_GOOGLE_SHEETS_API_KEY=
VITE_GOOGLE_SHEETS_RANGE=Jobs!A:J
